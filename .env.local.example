# Site URL — used for sitemap.xml and absolute URLs
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Brevo (email/SMS marketing) — https://app.brevo.com/settings/keys/api
# API key: Brevo → Account → SMTP & API → API Keys → Generate a new API key
BREVO_API_KEY=xkeysib-...
# List ID: Brevo → Contacts → Lists → click your list → the number in the URL (e.g. /contacts/list/3 → 3)
BREVO_LIST_ID=3

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
